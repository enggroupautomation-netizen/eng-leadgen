# Supabase (frontend — safe to expose)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Netlify Functions only (NEVER in frontend code)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
WEBHOOK_SECRET=your-random-secret-here

# Stripe (Netlify Functions only — set in Netlify Dashboard, NOT in .env.local)
# The publishable key, price ID, and webhook secret are also configurable
# from the admin Settings page in the app (stored in Supabase app_settings)
